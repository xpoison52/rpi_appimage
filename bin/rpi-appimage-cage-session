#!/bin/sh
# Wayland kiosk session: run Cage with the AppImage grid launcher.
# Installed to /usr/local/bin by install.sh (requires cage, python3-gi, gir1.2-gtk-3.0).
set -eu

LAUNCHER="${RPI_APPIMAGE_LAUNCHER:-/usr/local/lib/rpi-appimage-launcher/appimage_grid_launcher.py}"
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=CageAppImage

# Minimal Wayland sessions: AT-SPI D-Bus can leave GTK with a blank stage on some Pis.
export NO_AT_BRIDGE=1
unset GTK_MODULES 2>/dev/null || true
# If the UI is still a black screen, try once: export LIBGL_ALWAYS_SOFTWARE=1
if [ "${RPI_APPIMAGE_SOFTWARE_GL:-}" = 1 ]; then
  export LIBGL_ALWAYS_SOFTWARE=1
fi

if ! command -v cage >/dev/null 2>&1; then
  echo "cage not found. Install: sudo apt install cage" >&2
  exit 1
fi

if [ ! -f "$LAUNCHER" ]; then
  echo "Launcher not found: $LAUNCHER" >&2
  exit 1
fi

if command -v dbus-run-session >/dev/null 2>&1 && [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
  exec dbus-run-session cage -- /usr/bin/python3 "$LAUNCHER" ${1+"$@"}
else
  exec cage -- /usr/bin/python3 "$LAUNCHER" ${1+"$@"}
fi
